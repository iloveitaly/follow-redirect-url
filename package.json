    "http",
    "https",
    "node",
    "followRedirect",
    "domain"
  ],
  "contributors": [
    {
      "name": "Sayed Tauseef Naqvi",
      "email": "tauseef.naqvi786@gmail.com"
    },
    "Michael Bianco (https://mikebian.co/about)"
  ],
  "preferGlobal": true,
  "bin": {
    "follow": "bin.js",
    "follow-redirect-url": "bin.js"
  },
  "engines": {
    "node": ">=18"
  }
}
